# Discord
DISCORD_TOKEN=cole_o_token_do_bot_aqui
CLIENT_ID=cole_o_client_id_aqui

# Use GUILD_ID durante o desenvolvimento para os slash commands aparecerem na hora.
# Se deixar vazio, o deploy registra comandos globais e pode demorar.
GUILD_ID=

# IDs separados por virgula. Opcional.
OWNER_IDS=

# Cloud/storage
# Em hosts como Railway/Daki, deixe assim para salvar memoria/XP/lembretes em ./data.
DATA_DIR=./data
NODE_ENV=production

# Railway/Nixpacks
NIXPACKS_NODE_VERSION=24
PORT=3000

# AI
DEFAULT_AI_PROVIDER=openai
AI_SYSTEM_PROMPT=Voce e um assistente util, direto e amigavel dentro de um servidor Discord.
AI_MAX_HISTORY=12
AI_TIMEOUT_MS=45000
AI_MAX_TOKENS=900
AI_TEMPERATURE=0.7
AI_MEMORY_ENABLED=true
AI_REPLY_ON_MENTION=false
AI_RULES_CONTEXT_MESSAGES=15
AI_WEBSEARCH_SOURCES=6

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://localhost
OPENROUTER_APP_NAME=GameWallPro Bot

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Local AI via OpenAI-compatible endpoint, for example Ollama/LM Studio.
LOCAL_AI_ENABLED=false
LOCAL_AI_BASE_URL=http://localhost:11434/v1
LOCAL_AI_API_KEY=local
LOCAL_AI_MODEL=llama3.1

# Auto moderation
AUTO_MOD_ENABLED=false
AUTO_MOD_BLOCK_INVITES=false
AUTO_MOD_MAX_MENTIONS=8
AUTO_MOD_BLOCKED_WORDS=

# XP / levels
XP_ENABLED=true
XP_COOLDOWN_SECONDS=60
XP_MIN=10
XP_MAX=25
XP_LEVEL_UP_MESSAGES=true

# Music
MUSIC_MAX_QUEUE=50
MUSIC_DEFAULT_VOLUME=70
MUSIC_MAX_PLAYLIST_ITEMS=20

# Free games watcher
FREE_GAMES_CHECK_MINUTES=360
FREE_GAMES_MAX_RESULTS=12
FREE_GAMES_FULL_ONLY=true
